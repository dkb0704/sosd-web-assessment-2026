# ==========================================
# 通用后端项目 .gitignore 模版
# 涵盖: macOS, Java (Maven/Gradle), Node.js, IDE
# ==========================================

# --- 操作系统残留 ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- 后端构建与临时文件 ---
*.class
*.log
*.jar
*.war
*.ear
*.tar.gz
*.zip
*.rar
hs_err_pid*
replay_pid*

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.variants
pom.xml.next
release.properties

# Gradle
.gradle/
build/
!src/*/src

# Node.js (如果有前端/全栈)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

# --- IDE 及辅助工具 ---
.idea/
*.iml
*.iws
.project
.classpath
.settings/
.factorypath
.vscode/
*.code-workspace

# --- 环境变量 & 本地配置 ---
.env
.env.local
.env.*.local
config/secrets/
